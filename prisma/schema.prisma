generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── NextAuth required models ──────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Core user ─────────────────────────────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  image          String?
  password       String?
  displayName    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  gold           Int       @default(500)
  energy         Int       @default(100)
  xp             Int       @default(0)
  level          Int       @default(1)
  streak         Int       @default(0)
  focusMinutes   Int       @default(0)
  lastActiveDate String?
  lastMoodDate   String?
  houseLevel     Int       @default(1)
  happiness      Int       @default(50)

  themeMode      String    @default("light")
  uiTone         String    @default("sunrise")
  language       String    @default("en")

  lastLoginDate  String?
  loginStreak    Int       @default(0)

  plan           String    @default("free")
  planExpiry     DateTime?

  accounts            Account[]
  sessions            Session[]
  goals               Goal[]
  tasks               Task[]
  focusSessions       FocusSession[]
  city                City?
  purchases           Purchase[]
  moods               MoodCheckIn[]
  achievements        UserAchievement[]
  posts               Post[]
  comments            Comment[]
  likes               Like[]
  sentMessages        Message[]
  chatMembers         ChatMember[]
  notifications       Notification[]
  friendsSent         Friend[]  @relation("FriendRequester")
  friendsReceived     Friend[]  @relation("FriendTarget")
  companion           Companion?
  userDailyQuests     UserDailyQuest[]
  gameState           GameState?
  customRewards       CustomReward[]
  neighborhoodPosts   NeighborhoodPost[]
  neighborhoodReplies NeighborhoodReply[]
  neighborhoodLikes   NeighborhoodLike[]
}

// ── Goals & Tasks ─────────────────────────────────────────────────────────────

model Goal {
  id         String   @id @default(cuid())
  userId     String
  title      String
  deadline   String
  dailyHours Float    @default(3)
  energy     String   @default("balanced")
  difficulty Int      @default(3)
  category   String   @default("study")
  isActive   Boolean  @default(true)
  status     String   @default("active")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks      Task[]
}

model Task {
  id           String         @id @default(cuid())
  userId       String
  goalId       String?
  day          String
  title        String
  category     String
  minutes      Int
  difficulty   Int
  gold         Int
  xp           Int
  status       String         @default("pending")
  completion   Int            @default(0)
  focusMinutes Int            @default(0)
  isRecovery   Boolean        @default(false)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal         Goal?          @relation(fields: [goalId], references: [id], onDelete: SetNull)
  sessions     FocusSession[]

  @@index([userId, day])
  @@index([userId, status])
  @@index([goalId])
}

model FocusSession {
  id         String   @id @default(cuid())
  userId     String
  taskId     String?
  minutes    Int
  completion Int
  goldEarned Int
  xpEarned   Int
  startedAt  DateTime @default(now())
  endedAt    DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  task       Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([userId, startedAt])
  @@index([taskId])
}

// ── Game State ────────────────────────────────────────────────────────────────

model GameState {
  id                 String   @id @default(cuid())
  userId             String   @unique
  currentEra         String   @default("pioneer")
  prestigeCount      Int      @default(0)
  prestigeMultiplier Float    @default(1.0)
  lastLoginAt        DateTime @default(now())
  specialCitizens    Json     @default("[]")
  eventHistory       Json     @default("[]")
  todayEvent         Json?
  todayEventDate     String   @default("")
  totalBuilt           Int      @default(0)
  pendingGold          Int      @default(0)
  pendingEnergy        Int      @default(0)
  constructionDiscount Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── City Builder ──────────────────────────────────────────────────────────────

model City {
  id         String           @id @default(cuid())
  userId     String           @unique
  name       String           @default("My City")
  gridWidth  Int              @default(10)
  gridHeight Int              @default(8)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  buildings  PlacedBuilding[]
}

model PlacedBuilding {
  id             String   @id @default(cuid())
  cityId         String
  itemId         String
  name           String
  icon           String
  category       String   @default("Buildings")
  x              Int      @default(-1)
  y              Int      @default(-1)
  rotation       Int      @default(0)
  level          Int      @default(1)
  district       String   @default("residential")
  tier           Int      @default(1)
  health         String   @default("healthy")
  maintenanceDue DateTime @default(now())
  citizens       Int      @default(0)
  constructedAt  DateTime @default(now())
  placedAt       DateTime @default(now())
  city           City     @relation(fields: [cityId], references: [id], onDelete: Cascade)

  @@index([cityId, district])
  @@index([cityId, health])
}

// ── Shop & Inventory ──────────────────────────────────────────────────────────

model Purchase {
  id        String   @id @default(cuid())
  userId    String
  itemId    String
  itemName  String
  category  String
  cost      Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, itemId])
  @@index([userId, createdAt])
}

// ── Mood ──────────────────────────────────────────────────────────────────────

model MoodCheckIn {
  id          String   @id @default(cuid())
  userId      String
  tone        String
  answers     String[]
  goldAwarded Int
  date        String
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Achievements ──────────────────────────────────────────────────────────────

model Achievement {
  id          String            @id @default(cuid())
  key         String            @unique
  name        String
  description String
  icon        String
  goldReward  Int               @default(0)
  xpReward    Int               @default(0)
  users       UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime    @default(now())
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement   Achievement @relation(fields: [achievementId], references: [id])

  @@unique([userId, achievementId])
}

// ── Neighborhood / Social ─────────────────────────────────────────────────────

model Post {
  id        String    @id @default(cuid())
  userId    String
  content   String    @db.Text
  type      String    @default("text")
  metadata  Json?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments  Comment[]
  likes     Like[]
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  content   String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Like {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

// ── Chat ──────────────────────────────────────────────────────────────────────

model ChatRoom {
  id        String       @id @default(cuid())
  name      String?
  isGroup   Boolean      @default(false)
  createdAt DateTime     @default(now())
  messages  Message[]
  members   ChatMember[]
}

model ChatMember {
  id       String   @id @default(cuid())
  roomId   String
  userId   String
  joinedAt DateTime @default(now())
  room     ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
}

model Message {
  id        String   @id @default(cuid())
  roomId    String
  userId    String
  content   String
  createdAt DateTime @default(now())
  room      ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Friends / Neighbors ───────────────────────────────────────────────────────

model Friend {
  id          String   @id @default(cuid())
  requesterId String
  targetId    String
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  requester   User     @relation("FriendRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  target      User     @relation("FriendTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([requesterId, targetId])
}

// ── Notifications ─────────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  content   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Companion (Fovi) ──────────────────────────────────────────────────────────

model Companion {
  id         String    @id @default(cuid())
  userId     String    @unique
  friendship Int       @default(0)
  lastFed    DateTime?
  lastPetted DateTime?
  lastActive DateTime?
  skin       String    @default("default")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Daily Quests ──────────────────────────────────────────────────────────────

model UserDailyQuest {
  id        String    @id @default(cuid())
  userId    String
  questKey  String
  dateKey   String
  progress  Int       @default(0)
  completed Boolean   @default(false)
  claimed   Boolean   @default(false)
  claimedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, questKey, dateKey])
}

// ── Custom Personal Rewards ───────────────────────────────────────────────────

model CustomReward {
  id            String    @id @default(cuid())
  userId        String
  title         String
  description   String?
  coinsRequired Int
  icon          String    @default("🎁")
  unlockedAt    DateTime?
  claimedAt     DateTime?
  createdAt     DateTime  @default(now())
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ── Anonymous Neighborhood ────────────────────────────────────────────────────

model NeighborhoodPost {
  id            String             @id @default(cuid())
  userId        String
  content       String             @db.VarChar(500)
  goalTag       String?
  anonymousName String
  likesCount    Int                @default(0)
  createdAt     DateTime           @default(now())
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  replies       NeighborhoodReply[]
  likedBy       NeighborhoodLike[]

  @@index([createdAt])
  @@index([goalTag])
}

model NeighborhoodReply {
  id            String          @id @default(cuid())
  postId        String
  userId        String
  content       String          @db.VarChar(300)
  anonymousName String
  createdAt     DateTime        @default(now())
  post          NeighborhoodPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId])
}

model NeighborhoodLike {
  id     String          @id @default(cuid())
  postId String
  userId String
  post   NeighborhoodPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}
